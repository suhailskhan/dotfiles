window-width = 120
window-height = 30
window-padding-x = 5
window-theme = system
macos-titlebar-style = native
window-save-state = default
font-family = "SF Mono"
font-size = 11
font-thicken = true
cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor
bell-features = system, attention, title
mouse-hide-while-typing = true
